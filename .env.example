# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here

# Email Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USE_TLS=0
MAIL_USE_SSL=1
MAIL_USERNAME=anjalidadwal14@gmail.com
MAIL_PASSWORD=your-google-app-password
